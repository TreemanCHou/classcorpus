{
    "_comment": "可为每一个流程环节单独配置 LLM/Embedding 接入。未在 stages 中显式声明的环节会回退到 default。",
    "default": {
        "type": "chat",
        "api_key": "sk-5a6e444a24d44278b4e385b7e3e1fc4b",
        "base_url": "https://api.deepseek.com",
        "model": "deepseek-v4-pro",
        "temperature": 0.2,
        "max_tokens": 4096,
        "timeout": 120,
        "max_retries": 3,
        "retry_backoff": 2.0
    },
    "default_embedding": {
        "type": "embedding",
